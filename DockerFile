# Use the official Microsoft .NET SDK image to build the project
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

# 1. Note the folder uses a DASH (-) but the file inside uses a DASH (-) too!
COPY ["DNTS-CLIS/DNTS-CLIS.csproj", "DNTS-CLIS/"]
RUN dotnet restore "DNTS-CLIS/DNTS-CLIS.csproj"

# Copy the entire workspace code over
COPY . .

# Move inside the project folder to execute the compiler builds
WORKDIR "/src/DNTS-CLIS"
RUN dotnet build "DNTS-CLIS.csproj" -c Release -o /app/build

# Publish compilation binaries to output context
FROM build AS publish
RUN dotnet publish "DNTS-CLIS.csproj" -c Release -o /app/publish /p:UseAppHost=false

# Use the lightweight ASP.NET runtime image for final execution
FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS final
WORKDIR /app
COPY --from=publish /app/publish .

# Expose port 10000 for Render binding routing
ENV ASPNETCORE_URLS=http://+:10000
EXPOSE 10000

# Run the app assembly (Notice the assembly output compiles with an underscore)
ENTRYPOINT ["dotnet", "DNTS_CLIS.dll"]
