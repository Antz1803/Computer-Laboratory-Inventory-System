# Use the official Microsoft .NET SDK image to build the project
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

# Copy the csproj file from its subfolder and restore dependencies
COPY ["DNTS_CLIS/DNTS_CLIS.csproj", "DNTS_CLIS/"]
RUN dotnet restore "DNTS_CLIS/DNTS_CLIS.csproj"

# Copy the rest of the application files and build it
COPY . .
WORKDIR "/src/DNTS_CLIS"
RUN dotnet build "DNTS_CLIS.csproj" -c Release -o /app/build

# Publish the application to an optimized production folder
FROM build AS publish
RUN dotnet publish "DNTS_CLIS.csproj" -c Release -o /app/publish /p:UseAppHost=false

# Use the lightweight ASP.NET runtime image for final execution
FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS final
WORKDIR /app
COPY --from=publish /app/publish .

# Expose port 10000 for Render binding routing
ENV ASPNETCORE_URLS=http://+:10000
EXPOSE 10000

# Set the entry point to run the DNTS_CLIS DLL
ENTRYPOINT ["dotnet", "DNTS_CLIS.dll"]
